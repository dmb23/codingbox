# codingbox.yaml - Sandbox configuration
#
# See: https://github.com/mischa/codingbox

# OCI image to use for the sandbox (required)
image: "ubuntu:22.04"

# Working directory to mount into the container (default: current directory)
# workdir: "."

# Additional directory mounts
# mounts:
#   - source: "/path/to/shared/libs"
#     target: "/libs"
#     mode: "ro"         # ro (read-only, default) or rw (read-write)
#   - source: "/path/to/output"
#     target: "/output"
#     mode: "rw"

# Secrets: specify env var names. Real values are read from the host
# environment automatically. Inside the sandbox, env vars are set to
# auto-generated placeholders. The proxy replaces placeholders with
# real values in outbound requests.
# secrets:
#   - env: "ANTHROPIC_API_KEY"
#     replace_in: ["headers"]
#   - env: "GITHUB_TOKEN"
#     replace_in: ["headers", "body"]

# Port for the MITM proxy (0 = auto-assign)
# proxy_port: 0
